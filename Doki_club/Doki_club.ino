void setup() {
  pinMode(BUZZER_PIN, OUTPUT);
  delay(1000);
  playMelody();
}

void loop() {
  delay(5000);
  playMelody();
}

void playMelody() {
  int notes = sizeof(melody) / sizeof(melody[0]);
  int tempo = 104;

  for (int i = 0; i < notes; i++) {
    int note = pgm_read_word_near(melody + i);
    int dur  = pgm_read_word_near(durations + i);
    int noteDuration = (60000 / tempo) * (4.0 / dur);

    if (note == REST) {
      delay(noteDuration);
    } else {
      tone(BUZZER_PIN, note, noteDuration * 0.90);
      delay(noteDuration);
      noTone(BUZZER_PIN);
    }
    delay(6);
  }
}
